# Configuración del Bot WhatsApp - Publiya7
# Copiar este archivo a .env y completar los valores

# ============================================
# CONFIGURACIÓN WHATSAPP BUSINESS API (Meta)
# ============================================
# Token de acceso permanente de Meta
WHATSAPP_ACCESS_TOKEN=tu_token_aqui

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui

# Token de verificación para webhook
WHATSAPP_VERIFY_TOKEN=tu_verify_token_aqui

# URL de la API de WhatsApp
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# ============================================
# CONFIGURACIÓN BASE DE DATOS
# ============================================
DATABASE_PATH=database/pedidos.db

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
# Puerto para el servidor webhook
SERVER_PORT=8000

# Host del servidor (0.0.0.0 para aceptar conexiones externas)
SERVER_HOST=0.0.0.0

# Modo debug (True/False)
DEBUG_MODE=False

# ============================================
# CONFIGURACIÓN DE LOGS
# ============================================
# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Archivo de logs
LOG_FILE=logs/app.log

# ============================================
# CONFIGURACIÓN DE CLIENTES
# ============================================
# Cliente por defecto si no se detecta automáticamente
DEFAULT_CLIENTE_ID=publiya7

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA subir este archivo a Git (está en .gitignore)
# 2. Guardar backup de tokens en lugar seguro
# 3. Rotar tokens periódicamente
# 4. En producción, usar variables de entorno del servidor
